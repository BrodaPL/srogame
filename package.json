{
  "name": "srogame",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "smoke:test": "node scripts/run-smoke-tests.js",
    "mcp:smoke": "node scripts/run-mcp-smoke-tests.js",
    "bot:bench": "npx tsx scripts/run-bot-benchmarks.ts",
    "bot:smoke": "node scripts/run-bot-smoke-tests.js",
    "bot:sim": "npx tsx scripts/run-bot-v2-simulation.ts",
    "bot:sim:initial": "npx tsx scripts/run-bot-v2-simulation.ts --scenario=initial",
    "bot:sim:advanced": "npx tsx scripts/run-bot-v2-simulation.ts --scenario=advanced",
    "bot:sim:baseline": "npx tsx scripts/run-bot-sim-baselines.ts",
    "ships:descr": "node scripts/generate-ships-descr.ts",
    "defences:descr": "node scripts/generate-defences-descr.ts"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/router": "^21.2.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "jsdom": "^27.1.0",
    "playwright": "^1.56.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
